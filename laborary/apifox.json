                    "first_page_url": "http://localhost:8000/api/admin/applications?page=1",
                    "from": 1,
                    "last_page": 1,
                    "last_page_url": "http://localhost:8000/api/admin/applications?page=1",
                    "next_page_url": null,
                    "path": "http://localhost:8000/api/admin/applications",
                    "per_page": 15,
                    "prev_page_url": null,
