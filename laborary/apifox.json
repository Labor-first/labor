{
  "openapi": "3.0.0",
  "info": {
    "title": "Laborary Admin API",
    "description": "后台管理接口文档",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "本地开发服务器"
    }
  ],
  "tags": [
    {
      "name": "Application",
      "description": "报名管理接口"
    },
    {
      "name": "User",
      "description": "用户管理接口"
    },
    {
      "name": "System",
      "description": "系统管理接口"
    }
  ],
  "paths": {
    "/api/admin/applications": {
      "get": {
        "tags": ["Application"],
        "summary": "获取报名列表",
        "description": "分页、搜索、筛选报名数据",
        "parameters": [
          {
            "name": "keyword",
            "in": "query",
            "description": "搜索关键词（账号/姓名/手机号）",
            "schema": {
              "type": "string"
            },
            "example": "张三"
          },
          {
            "name": "status",
            "in": "query",
            "description": "状态筛选（1=待审核, 2=已通过, 3=已取消, 4=已拒绝）",
            "schema": {
              "type": "integer",
              "enum": [1, 2, 3, 4]
            },
            "example": 1
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "每页数量",
            "schema": {
              "type": "integer",
              "default": 15
            },
            "example": 15
          }
        ],
        "responses": {
          "200": {
            "description": "成功获取报名列表",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "data": {
                    "current_page": 1,
                    "data": [
                      {
                        "id": 1,
                        "user_id": 1,
                        "config_id": 1,
