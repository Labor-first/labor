{
  "openapi": "3.0.0",
  "info": {
    "title": "报名审核接口",
    "version": "1.0.0"
  },
  "paths": {
    "/api/admin/applications/{id}/audit": {
      "put": {
        "summary": "审核报名申请",
        "tags": ["报名管理"],
        "security": [{"bearerAuth": []}],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {"type": "integer", "example": 1}
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {"type": "integer", "example": 2},
                  "audit_remark": {"type": "string", "example": "符合录取条件，予以通过"}
                }
              },
              "example": {
                "status": 2,
                "audit_remark": "符合录取条件，予以通过"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "message": "审核通过，已录取",
                  "data": {
                    "id": 1,
                    "user_id": "2021001001",
                    "name": "张三",
                    "class": "计算机2101班",
                    "academy": "信息工程学院",
                    "major": "计算机科学与技术",
                    "sign_reason": "对实验室研究方向感兴趣",
                    "status": 2,
                    "status_text": "已通过",
                    "audit_remark": "符合录取条件，予以通过",
                    "audit_time": "2024-01-15 14:30:00",
                    "created_at": "2024-01-10 09:00:00",
                    "updated_at": "2024-01-15 14:30:00",
                    "user": {
                      "id": 1,
                      "account": "2021001001",
                      "username": "张三",
                      "email": "zhangsan@example.com",
                      "phone": "13800138000"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}