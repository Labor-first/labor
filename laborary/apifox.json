{
  "openapi": "3.0.0",
  "info": {
    "title": "实验室管理系统 - FAQ管理接口",
    "version": "1.0.0",
    "description": "管理员FAQ问题管理接口文档"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8000/api",
      "description": "本地开发服务器"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "username": {
            "type": "string",
            "example": "徐杰"
          }
        }
      },
      "Question": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "title": {
            "type": "string",
            "example": "测试提问标题"
          },
          "content": {
            "type": "string",
            "example": "这是问题的详细内容"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "answered", "resolved"],
            "example": "answered"
          },
          "answer": {
            "type": "string",
            "example": "这是问题的回答内容"
          },
          "user": {
            "$ref": "#/components/schemas/User"
          },
          "answerer": {
            "$ref": "#/components/schemas/User"
          },
          "answered_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-03-31 19:16:33"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-04-01 03:16:33"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-03-31 19:16:33"
          }
        }
      },
      "Pagination": {
        "type": "object",
        "properties": {
          "current_page": {
            "type": "integer",
            "example": 1
          },
          "per_page": {
            "type": "integer",
            "example": 10
          },
          "total": {
            "type": "integer",
            "example": 100
          },
          "last_page": {
            "type": "integer",
            "example": 10
          }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 200
          },
          "msg": {
            "type": "string",
            "example": "操作成功"
          },
          "data": {
            "type": "object"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "example": 400
          },
          "msg": {
            "type": "string",
            "example": "参数错误"
          },
          "data": {
            "type": "object",
            "example": null
          }
        }
      }
    }
  },
  "paths": {
    "/admin/faqs": {
      "get": {
        "summary": "获取问题列表",
        "description": "管理员获取所有问题列表，支持关键词搜索、状态筛选和分页",
        "tags": ["FAQ管理"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "keyword",
            "in": "query",
            "description": "搜索关键词（标题、内容、回答）",
            "schema": {
              "type": "string"
            },
            "example": "实验室"
          },
          {
            "name": "status",
            "in": "query",
            "description": "状态筛选",
            "schema": {
              "type": "string",
              "enum": ["pending", "answered", "resolved"]
            },
            "example": "answered"
          },
          {
            "name": "is_answered",
            "in": "query",
            "description": "是否已回答（1=已回答，0=未回答）",
            "schema": {
              "type": "integer",
              "enum": [0, 1]
            },
            "example": 1
          },
          {
            "name": "per_page",
            "in": "query",
            "description": "每页数量",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            },
            "example": 10
          },
          {
            "name": "page",
            "in": "query",
            "description": "页码",
            "schema": {
              "type": "integer",
              "minimum": 1
            },
            "example": 1
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/SuccessResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "allOf": [
                            {
                              "$ref": "#/components/schemas/Pagination"
                            },
                            {
                              "type": "object",
                              "properties": {
                                "data": {
                                  "type": "array",
                                  "items": {
                                    "$ref": "#/components/schemas/Question"
                                  }
                                }
                              }
                            }
                          ]
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "code": 200,
                  "msg": "获取成功",
                  "data": {
                    "current_page": 1,
                    "data": [
                      {
                        "id": 1,
                        "user_id": 9,
                        "title": "测试提问标题",
                        "content": "这是问题的详细内容",
                        "status": "answered",
                        "answer": "这是问题的回答内容",
                        "answered_by": 9,
                        "answered_at": "2026-03-31 19:16:33",
                        "created_at": "2026-04-01 03:16:33",
                        "updated_at": "2026-03-31 19:16:33",
                        "user": {
                          "id": 9,
                          "username": "徐杰"
                        },
                        "answerer": {
                          "id": 9,
                          "username": "徐杰"
                        }
                      }
                    ],
                    "per_page": 10,
                    "total": 1,
                    "last_page": 1
                  }
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "code": 401,
                  "msg": "未登录或登录已过期，请先登录",
                  "data": null
                }
              }
            }
          },
          "403": {
            "description": "无权限",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "code": 403,
                  "msg": "无权访问管理后台",
                  "data": null
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "新增问题",
        "description": "管理员创建新问题，可选择是否直接回答",
        "tags": ["FAQ管理"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title", "content"],
                "properties": {
                  "title": {
                    "type": "string",
                    "maxLength": 255,
                    "description": "问题标题"
                  },
                  "content": {
                    "type": "string",
                    "description": "问题内容"
                  },
                  "answer": {
                    "type": "string",
                    "description": "回答内容（可选，如果提供则自动标记为已回答）"
                  }
                }
              },
              "example": {
                "title": "测试提问标题",
                "content": "这是问题的详细内容",
                "answer": "可选的回答内容"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "创建成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/SuccessResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/Question"
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "code": 200,
                  "msg": "问题创建成功",
                  "data": {
                    "id": 1,
                    "user_id": 9,
                    "title": "测试提问标题",
                    "content": "这是问题的详细内容",
                    "status": "answered",
                    "answer": "可选的回答内容",
                    "answered_by": 9,
                    "answered_at": "2026-03-31 19:16:33",
                    "created_at": "2026-04-01 03:16:33",
                    "updated_at": "2026-03-31 19:16:33",
                    "user": {
                      "id": 9,
                      "username": "徐杰"
                    },
                    "answerer": {
                      "id": 9,
                      "username": "徐杰"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "code": 400,
                  "msg": "参数错误",
                  "data": {
                    "title": ["问题标题不能为空"]
                  }
                }
              }
            }
          }
        }
      }
    },
    "/admin/faqs/{id}": {
      "get": {
        "summary": "获取单个问题详情",
        "description": "管理员获取任意问题的详细信息",
        "tags": ["FAQ管理"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "问题ID",
            "schema": {
              "type": "integer"
            },
            "example": 1
          }
        ],
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/SuccessResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/Question"
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "code": 200,
                  "msg": "获取成功",
                  "data": {
                    "id": 1,
                    "user_id": 9,
                    "title": "测试提问标题",
                    "content": "这是问题的详细内容",
                    "status": "answered",
                    "answer": "这是问题的回答内容",
                    "answered_by": 9,
                    "answered_at": "2026-03-31 19:16:33",
                    "created_at": "2026-04-01 03:16:33",
                    "updated_at": "2026-03-31 19:16:33",
                    "user": {
                      "id": 9,
                      "username": "徐杰"
                    },
                    "answerer": {
                      "id": 9,
                      "username": "徐杰"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "问题不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "code": 404,
                  "msg": "问题不存在",
                  "data": null
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "修改问题",
        "description": "管理员修改任意问题的标题、内容、回答或状态",
        "tags": ["FAQ管理"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "问题ID",
            "schema": {
              "type": "integer"
            },
            "example": 1
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "maxLength": 255,
                    "description": "问题标题"
                  },
                  "content": {
                    "type": "string",
                    "description": "问题内容"
                  },
                  "answer": {
                    "type": "string",
                    "description": "回答内容（如果问题状态为pending，回答后会自动变为answered）"
                  },
                  "status": {
                    "type": "string",
                    "enum": ["pending", "answered", "resolved"],
                    "description": "问题状态"
                  }
                }
              },
              "example": {
                "title": "修改后的问题标题",
                "content": "修改后的问题内容",
                "answer": "这是管理员回答的内容",
                "status": "answered"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/SuccessResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "$ref": "#/components/schemas/Question"
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "code": 200,
                  "msg": "问题更新成功",
                  "data": {
                    "id": 1,
                    "user_id": 9,
                    "title": "修改后的问题标题",
                    "content": "修改后的问题内容",
                    "status": "answered",
                    "answer": "这是管理员回答的内容",
                    "answered_by": 9,
                    "answered_at": "2026-03-31 19:16:33",
                    "created_at": "2026-04-01 03:16:33",
                    "updated_at": "2026-03-31 19:16:33",
                    "user": {
                      "id": 9,
                      "username": "徐杰"
                    },
                    "answerer": {
                      "id": 9,
                      "username": "徐杰"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "问题不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "code": 404,
                  "msg": "问题不存在",
                  "data": null
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "删除问题",
        "description": "管理员删除任意问题",
        "tags": ["FAQ管理"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "问题ID",
            "schema": {
              "type": "integer"
            },
            "example": 1
          }
        ],
        "responses": {
          "200": {
            "description": "删除成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                },
                "example": {
                  "code": 200,
                  "msg": "问题已删除",
                  "data": null
                }
              }
            }
          },
          "404": {
            "description": "问题不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "code": 404,
                  "msg": "问题不存在",
                  "data": null
                }
              }
            }
          }
        }
      }
    },
    "/admin/faqs/answer-all": {
      "post": {
        "summary": "批量回答问题",
        "description": "管理员批量回答多个问题",
        "tags": ["FAQ管理"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["answers"],
                "properties": {
                  "answers": {
                    "type": "array",
                    "description": "回答列表",
                    "items": {
                      "type": "object",
                      "required": ["id", "answer"],
                      "properties": {
                        "id": {
                          "type": "integer",
                          "description": "问题ID"
                        },
                        "answer": {
                          "type": "string",
                          "description": "回答内容"
                        }
                      }
                    }
                  }
                }
              },
              "example": {
                "answers": [
                  {
                    "id": 1,
                    "answer": "这是第一个问题的回答"
                  },
                  {
                    "id": 2,
                    "answer": "这是第二个问题的回答"
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "批量回答成功",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    {
                      "$ref": "#/components/schemas/SuccessResponse"
                    },
                    {
                      "type": "object",
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "updated_count": {
                              "type": "integer"
                            },
                            "errors": {
                              "type": "array"
                            }
                          }
                        }
                      }
                    }
                  ]
                },
                "example": {
                  "code": 200,
                  "msg": "成功回答 2 个问题",
                  "data": {
                    "updated_count": 2,
                    "errors": []
                  }
                }
              }
            }
          },
          "400": {
            "description": "参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "code": 400,
                  "msg": "参数错误",
                  "data": {
                    "answers": ["回答数据不能为空"]
                  }
                }
              }
            }
          }
        }
      }
    },
    "/admin/faqs/batch-delete": {
      "post": {
        "summary": "批量删除问题",
        "description": "管理员批量删除多个问题",
        "tags": ["FAQ管理"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["ids"],
                "properties": {
                  "ids": {
                    "type": "array",
                    "description": "问题ID列表",
                    "items": {
                      "type": "integer"
                    }
                  }
                }
              },
              "example": {
                "ids": [1, 2, 3]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "批量删除成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                },
                "example": {
                  "code": 200,
                  "msg": "成功删除 3 个问题",
                  "data": null
                }
              }
            }
          },
          "400": {
            "description": "参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "code": 400,
                  "msg": "参数错误",
                  "data": {
                    "ids": ["请选择要删除的问题"]
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}