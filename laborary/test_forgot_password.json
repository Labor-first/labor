{
  "info": {
    "name": "忘记密码接口测试",
    "description": "测试忘记密码功能的接口集合"
  },
  "tests": [
    {
      "name": "1. 发送验证码",
      "method": "POST",
      "url": "http://localhost:8000/api/forgot-password/send-code",
      "headers": {
        "Content-Type": "application/json",
        "Accept": "application/json"
      },
      "body": {
        "account": "test001",
        "email": "test@example.com"
      },
      "description": "发送验证码到用户邮箱，验证码有效期10分钟"
    },
    {
      "name": "2. 重置密码",
      "method": "POST",
      "url": "http://localhost:8000/api/forgot-password/reset",
      "headers": {
        "Content-Type": "application/json",
        "Accept": "application/json"
      },
      "body": {
        "account": "test001",
        "email": "test@example.com",
        "code": "123456",
        "new_password": "newpassword123",
        "new_password_confirmation": "newpassword123"
      },
      "description": "使用验证码重置密码，验证码为6位数字"
    },
    {
      "name": "3. 发送验证码 - 用户不存在",
      "method": "POST",
      "url": "http://localhost:8000/api/forgot-password/send-code",
      "headers": {
        "Content-Type": "application/json",
        "Accept": "application/json"
      },
      "body": {
        "account": "notexist",
        "email": "notexist@example.com"
      },
      "expected_status": 404,
      "description": "测试用户不存在的错误处理"
    },
    {
      "name": "4. 重置密码 - 验证码错误",
      "method": "POST",
      "url": "http://localhost:8000/api/forgot-password/reset",
      "headers": {
        "Content-Type": "application/json",
        "Accept": "application/json"
      },
      "body": {
        "account": "test001",
        "email": "test@example.com",
        "code": "000000",
        "new_password": "newpassword123",
        "new_password_confirmation": "newpassword123"
      },
      "expected_status": 400,
      "description": "测试验证码错误的处理"
    },
    {
      "name": "5. 重置密码 - 验证码过期",
      "method": "POST",
      "url": "http://localhost:8000/api/forgot-password/reset",
      "headers": {
        "Content-Type": "application/json",
        "Accept": "application/json"
      },
      "body": {
        "account": "test001",
        "email": "test@example.com",
        "code": "123456",
        "new_password": "newpassword123",
        "new_password_confirmation": "newpassword123"
      },
      "expected_status": 400,
      "description": "测试验证码过期的处理（需要等待10分钟后测试）"
    }
  ],
  "test_users": [
    {
      "account": "test001",
      "username": "测试用户",
      "email": "test@example.com",
      "phone": "13800138000"
    },
    {
      "account": "zhangsan",
      "username": "张三",
      "email": "zhangsan@lab.com",
      "phone": "13800000001"
    }
  ]
}
